# ===========================================
# AI Sales Outreach Agent - Environment Config
# ===========================================
# Copy this file to .env and fill in your keys

# OpenAI API Key (required for email generation)
OPENAI_API_KEY=sk-your-openai-key-here

# Tavily API Key (required for prospect research)
TAVILY_API_KEY=tvly-your-tavily-key-here

# Notion CRM Integration
NOTION_API_KEY=ntn_your-notion-key-here
NOTION_DATABASE_ID=your-notion-database-id-here

# Gmail OAuth2 (place credentials.json in project root)
# After first auth, token.json will be auto-created
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Application Settings
APP_ENV=development
MOCK_MODE=true
DATABASE_URL=sqlite:///./sales_outreach.db
CHROMA_PERSIST_DIR=./chroma_db
